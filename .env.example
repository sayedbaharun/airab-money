DATABASE_URL="postgresql://USER:PASSWORD@YOUR-RAILWAY-POSTGRES-HOST/DBNAME?sslmode=require"
ADMIN_PASSWORD="set_a_strong_admin_password"

# OpenAI (optional; graceful fallback if missing)
OPENAI_API_KEY="your_openai_api_key"
OPENAI_TEXT_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="dall-e-3"

# Finnhub (optional; market-data endpoint falls back to indicative static payload if missing)
FINNHUB_API_KEY=""

# Resend (optional; newsletter subscribe will skip confirmation email if missing)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AIRAB Money <hello@airabmoney.com>"

# Uploads — mount a persistent Railway Volume here in production
UPLOAD_DIR="./uploads"

# Public base URL used for building email links (confirm/unsubscribe). No trailing slash.
PUBLIC_BASE_URL="http://localhost:3001"

# Feature flags
VITE_ENABLE_VOICE_DEMO="false"

PORT=3001
